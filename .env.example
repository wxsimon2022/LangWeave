# Copy to .env and fill in values

# ===== Chat Model =====

# DeepSeek (default provider)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
LANGWEAVE_MODEL=deepseek:deepseek-chat
# LANGWEAVE_MODEL=deepseek:deepseek-reasoner
# LANGWEAVE_TEMPERATURE=0.3
# LANGWEAVE_MAX_TOKENS=4096

# OpenAI (optional)
# OPENAI_API_KEY=sk-your-openai-api-key
# LANGWEAVE_MODEL=openai:gpt-4o-mini

# LANGWEAVE_SYSTEM_PROMPT=You are a helpful assistant.
# LANGWEAVE_DEBUG=false
# LANGWEAVE_MEMORY_ENABLED=true

# ===== Database / Memory (MySQL required) =====

# MySQL is required for ALL environments (dev, test, prod).
# LangGraph conversation memory (checkpointer) uses AIOMySQLSaver.
# The application will fail to start if this is not set correctly.
LANGWEAVE_DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/langweave

# ===== JWT =====
# LANGWEAVE_JWT_SECRET=change-this-in-production
# LANGWEAVE_JWT_EXPIRE_MINUTES=10080

# ===== CORS =====
# LANGWEAVE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
